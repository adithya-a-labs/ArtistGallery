# Shared local development defaults.
# Copy to .env only for local use. Do not commit real secrets.

# PostgreSQL connection string used by Drizzle and the Express API.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Optional when serving the React frontend from Vercel and the API from Railway.
# Use a comma-separated list if you need multiple allowed browser origins.
CORS_ORIGIN=http://localhost:5000,https://your-vercel-app.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Railway provides PORT automatically. Locally the server falls back to 5000.
PORT=5000
